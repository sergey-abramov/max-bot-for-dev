BOT_TOKEN=your_maxbot_token_here
PORT=3000

# Строка подключения к основной БД (используется приложением и миграциями Alembic)
# Пример:
# DATABASE_URL=postgresql+psycopg://maxbot:maxbot@db:5432/maxbot
DATABASE_URL=

# Опциональная строка подключения к ТЕСТОВОЙ БД.
# Если указана, pytest-тесты для модуля БД будут использовать именно её.
# Если не указана, тесты будут использовать DATABASE_URL.
TEST_DATABASE_URL=

# Настройки OpenRouter для чата с ИИ
# Обязательный ключ для доступа к OpenRouter API
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Идентификатор модели по умолчанию
# Примеры:
#   qwen/qwen-2.5-7b-instruct
#   nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_MODEL=qwen/qwen-2.5-7b-instruct

# Настройки STT (локальный сервис на faster-whisper)
STT_API_URL=http://stt:8000/transcribe
STT_MODEL=small

# URL сервиса викторины (FastAPI), доступный из контейнера бота
# Пример для docker-compose:
# QUIZ_API_URL=http://quiz-api:8001
QUIZ_API_URL=