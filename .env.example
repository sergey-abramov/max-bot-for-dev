# Токен бота для webhook/API runtime (Python)
MAX_BOT_TOKEN=your_maxbot_token_here
# Legacy polling runtime (web/) может читать BOT_TOKEN
BOT_TOKEN=
PORT=3000

# Строка подключения к основной БД (managed Postgres, используется приложением и Alembic)
# Пример (Neon/Supabase/RDS):
# DATABASE_URL=postgresql+psycopg://user:password@db.example.com:5432/maxbot?sslmode=require
DATABASE_URL=

# Опциональная строка подключения к ТЕСТОВОЙ БД.
# Если указана, pytest-тесты для модуля БД будут использовать именно её.
# Если не указана, тесты будут использовать DATABASE_URL.
TEST_DATABASE_URL=

# Настройки OpenRouter для чата с ИИ
# Обязательный ключ для доступа к OpenRouter API
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Идентификатор модели по умолчанию
# Примеры:
#   qwen/qwen-2.5-7b-instruct
#   nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_MODEL=qwen/qwen-2.5-7b-instruct

# Фича-флаг STT для голосовых сообщений (этап 1 Vercel-митрации: false)
# true включает попытку распознавания голоса через STT_API_URL.
MAX_STT_ENABLED=false

# Настройки STT (внешний managed endpoint; можно оставить пустым, если MAX_STT_ENABLED=false)
# Пример:
# STT_API_URL=https://stt.example.com/transcribe
STT_API_URL=
STT_MODEL=small

# URL API сервиса викторины (публичный URL деплоя)
# Пример:
# QUIZ_API_URL=https://your-app.vercel.app
QUIZ_API_URL=

# MAX webhook settings
MAX_WEBHOOK_SECRET=
MAX_WEBHOOK_PATH=/webhooks/max
MAX_WEBHOOK_SECRET_HEADER=X-Max-Webhook-Secret
# webhook only in production runtime (polling allowed only for local dev entrypoint)
MAX_BOT_MODE=webhook